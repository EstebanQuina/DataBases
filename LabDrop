.tables

--Create a table proglang_tbluk
CREATE TABLE proglang_tbluk (id INTEGER  NOT NULL PRIMARY KEY, language VARCHAR(20) NOT NULL UNIQUE, author VARCHAR(25) NOT NULL, year INTEGER NOT NULL, standard VARCHAR(10) NULL);
--Insert a record into proglang_tbluk
INSERT INTO proglang_tbluk (id, language, author, year, standard) VALUES (1, 'Prolog', 'Colmerauer', 1972, 'ISO');
INSERT INTO proglang_tbluk (id, language, author, year) VALUES (2, 'Perl', 'Wall', 1987);
INSERT INTO proglang_tbluk (id, language, author, year, standard) VALUES (3, 'APL', 'Iverson', 1964, 'ANSI');

select * from proglang_tbluk;

--Creating new tables from existing tables
CREATE TABLE proglang_tbl AS SELECT * FROM proglang_tbluk;
select * from proglang_tbl;
-- Look that the same values appear in the new table proglang_tbl as in proglang_tbluk. However, the new table proglang_tbl does not have the UNIQUE constraint on the language column, nor the NOT NULL constraint on the standard column. This is because when we create a new table using a SELECT statement, only the data is copied, but not the constraints or indexes from the original table.
.schema proglang_tbluk
.schema proglang_tbl

--Modifying tables
ALTER TABLE proglang_tbluk ALTER COLUMN  author TYPE VARCHAR(30);
--SQLIE3 does not support the ALTER COLUMN statement, so we cannot change the data type of the author column in the proglang_tbluk table. However, we can achieve a similar result by creating a new table with the desired structure and copying the data from the original table to the new table. Here is how we can do it:
ALTER TABLE proglang_tbluk ADD COLUMN current_status VARCHAR(32) NULL;
.schema proglang_tbluk

